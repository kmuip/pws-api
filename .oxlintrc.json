{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import", "oxc"],
  "env": {
    "browser": true,
    "es6": true,
    "node": true
  },
  "globals": {
    "Bun": "readonly"
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "ignorePatterns": [
    "node_modules/**",
    "packages/*/dist/**",
    "docs/passwordsafe/reference-site/**",
    "help.passwordsafe.de/**",
    "packages/pws-api/src/generated/forward-manifests.ts",
    "packages/pws-api/src/generated/runtime-enums.ts",
    "packages/pws-api/parity-manifest.json",
    "bun.lock",
    "package-lock.json"
  ]
}
