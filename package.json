{
  "name": "passwordsafe-agent-toolkit-workspace",
  "private": true,
  "packageManager": "bun@1.3.12",
  "license": "MIT",
  "homepage": "https://www.kmupartnergroup.ch",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "docs:mirror": "node ./scripts/mirror-passwordsafe-docs.mjs",
    "skill:build-docs": "python3 ./scripts/build-skill-reference-docs.py",
    "skill:validate": "python3 /home/luke/.codex/skills/.system/skill-creator/scripts/quick_validate.py skills/pws-api",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "api:check": "cd packages/pws-api && bun run check",
    "api:build": "cd packages/pws-api && bun run build",
    "api:live-auth-flow-smoke": "cd packages/pws-api && bun run live:auth-flow-smoke",
    "api:live-password-auth-smoke": "cd packages/pws-api && bun run live:password-auth-smoke",
    "api:pack": "cd packages/pws-api && bun publish --dry-run --access public",
    "types:check": "cd packages/pws-types && bun run check",
    "types:build": "cd packages/pws-types && bun run build",
    "types:pack": "cd packages/pws-types && bun publish --dry-run --access public"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/node-forge": "^1.3.14",
    "@types/ws": "^8.18.1",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3"
  }
}
