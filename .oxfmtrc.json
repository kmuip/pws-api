{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules/**",
    "packages/*/dist/**",
    "docs/passwordsafe/reference-site/**",
    "help.passwordsafe.de/**",
    "**/*.md",
    "packages/pws-api/src/generated/forward-manifests.ts",
    "packages/pws-api/src/generated/runtime-enums.ts",
    "packages/pws-api/parity-manifest.json",
    "bun.lock",
    "package-lock.json"
  ]
}
